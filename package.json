{
  "name": "open-mod-header",
  "description": "Open source tool to modify HTTP request and response headers.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
