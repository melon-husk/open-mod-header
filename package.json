    "@semantic-release/git": "^10.0.1",
    "@types/chrome": "^0.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "semantic-release": "^24.2.9",
    "typescript": "^5.9.3",
    "wxt": "^0.20.27"
  }
}
